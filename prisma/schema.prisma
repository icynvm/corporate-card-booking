generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  USER
  MANAGER
  FA
}

enum BillingType {
  ONE_TIME
  MONTHLY
  YEARLY
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

enum ReceiptStatus {
  UPLOADED
  VERIFIED
}

model User {
  id         String    @id @default(cuid())
  name       String
  email      String    @unique
  department String
  role       Role      @default(USER)
  requests   Request[]
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@map("users")
}

model Project {
  id              String    @id @default(cuid())
  projectName     String
  totalBudget     Float
  remainingBudget Float
  requests        Request[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("projects")
}

model Request {
  id                   String        @id @default(cuid())
  reqId                String        @unique @map("req_id")
  eventId              String?       @map("event_id")
  userId               String        @map("user_id")
  user                 User          @relation(fields: [userId], references: [id])
  projectId            String?       @map("project_id")
  project              Project?      @relation(fields: [projectId], references: [id])
  projectName          String?       @map("project_name")
  amount               Float
  objective            String
  contactNo            String        @map("contact_no")
  email                String        @default("dev@company.com")
  fullName             String?       @map("full_name")
  department           String?
  billingType          BillingType   @map("billing_type")
  startDate            DateTime      @map("start_date")
  endDate              DateTime      @map("end_date")
  bookingDate          DateTime?     @map("booking_date")
  effectiveDate        DateTime?     @map("effective_date")
  status               RequestStatus @default(PENDING)
  promotionalChannels  Json?         @map("promotional_channels")
  eventDetails         Json?         @map("event_details")
  accountCode          String?       @map("account_code")
  creditCardNo         String?       @map("credit_card_no")
  pdfUrl               String?       @map("pdf_url")
  approvalToken        String?       @unique @map("approval_token")
  approvalTokenExpiry  DateTime?     @map("approval_token_expiry")
  approvalNotes        String?       @map("approval_notes")
  approvalFileUrl      String?       @map("approval_file_url")
  createdAt            DateTime      @default(now()) @map("created_at")
  updatedAt            DateTime      @updatedAt @map("updated_at")
  receipts             Receipt[]

  @@map("requests")
}

model Receipt {
  id             String        @id @default(cuid())
  request        Request       @relation(fields: [requestId], references: [id])
  requestId      String
  monthYear      String
  receiptFileUrl String
  status         ReceiptStatus @default(UPLOADED)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@map("receipts")
}
